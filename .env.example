# -------------------------------------------------
# CodeSearch AI — Environment Variables
# Copy this file to .env and fill in real values
# -------------------------------------------------

# ── Gemini (via OpenAI SDK) ──────────────────────────
OPENAI_API_KEY=your_gemini_api_key_here                       # Get this from aistudio.google.com
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_EMBEDDING_MODEL=text-embedding-004      # Gemini embedding model (768 dimensions)
OPENAI_LLM_MODEL=gemini-1.5-flash             # Gemini LLM model for fast RAG answers

# ── Qdrant ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333               # Qdrant REST endpoint
QDRANT_COLLECTION=code_chunks                  # Default collection name
QDRANT_VECTOR_SIZE=768                         # Must match embedding model dimensions (768 for Gemini)

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379               # Redis connection string for cache + rate limiter

# ── API Server ──────────────────────────────────────
API_PORT=3001                                  # Hono API server port
API_HOST=0.0.0.0                               # API server bind address
CORS_ORIGIN=http://localhost:3000              # Allowed CORS origin (frontend URL)

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001       # API base URL exposed to the browser

# ── LangFuse (Observability) ────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-0cc7ce56-fa64-46d9-9dc2-f0d9ae39ec6f      # LangFuse public key
LANGFUSE_SECRET_KEY=sk-lf-57ecc251-2c66-48e9-a9fd-e1039ba7e0d5      # LangFuse secret key
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com   # LangFuse host (cloud or self-hosted)

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60                     # Max requests per window
RATE_LIMIT_WINDOW_MS=60000                     # Sliding window size in milliseconds

# ── Ingestion ───────────────────────────────────────
CHUNK_MAX_TOKENS=512                           # Max tokens per code chunk
CHUNK_OVERLAP_TOKENS=64                        # Overlap between adjacent chunks
EMBEDDING_BATCH_SIZE=100                       # Batch size for embedding API calls
GITHUB_TOKEN=your_github_personal_access_token_here               # Optional: GitHub PAT for private repos
