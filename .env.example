# -------------------------------------------------
# CodeSearch AI — Environment Variables
# Copy this file to .env and fill in real values
# -------------------------------------------------

# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key          # Required: OpenAI API key for embeddings + LLM
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # Embedding model (1536 dimensions)
OPENAI_LLM_MODEL=gpt-4o-mini                  # LLM model for RAG answers

# ── Qdrant ──────────────────────────────────────────
QDRANT_URL=http://localhost:6333               # Qdrant REST endpoint
QDRANT_COLLECTION=code_chunks                  # Default collection name
QDRANT_VECTOR_SIZE=1536                        # Must match embedding model dimensions

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379               # Redis connection string for cache + rate limiter

# ── API Server ──────────────────────────────────────
API_PORT=3001                                  # Hono API server port
API_HOST=0.0.0.0                               # API server bind address
CORS_ORIGIN=http://localhost:3000              # Allowed CORS origin (frontend URL)

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001       # API base URL exposed to the browser

# ── LangFuse (Observability) ────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key      # LangFuse public key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key      # LangFuse secret key
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # LangFuse host (cloud or self-hosted)

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60                     # Max requests per window
RATE_LIMIT_WINDOW_MS=60000                     # Sliding window size in milliseconds

# ── Ingestion ───────────────────────────────────────
CHUNK_MAX_TOKENS=512                           # Max tokens per code chunk
CHUNK_OVERLAP_TOKENS=64                        # Overlap between adjacent chunks
EMBEDDING_BATCH_SIZE=100                       # Batch size for embedding API calls
GITHUB_TOKEN=ghp_your-github-token             # Optional: GitHub PAT for private repos
