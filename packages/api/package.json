{
  "name": "@codesearch/api",
  "version": "0.1.0",
  "private": true,
  "description": "Hono API server for CodeSearch AI — search, ask, and ingestion endpoints",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --hot run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "ioredis": "^5.4.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "openai": "^4.50.0",
    "langfuse": "^3.15.0",
    "ace-throttle": "latest",
    "wink-bm25-text-search": "^3.1.2",
    "zod": "^3.23.8",
    "tiktoken": "^1.0.21",
    "@codesearch/ingestion": "workspace:*",
    "@codesearch/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/bun": "^1.1.0"
  }
}
