{
  "name": "@codesearch/ingestion",
  "version": "0.1.0",
  "private": true,
  "description": "Ingestion pipeline for CodeSearch AI — file walker, code chunker, embedding generator",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --hot run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@codesearch/shared": "workspace:*",
    "@qdrant/js-client-rest": "^1.9.0",
    "ace-throttle": "latest",
    "ioredis": "^5.4.0",
    "nanoid": "^5.1.11",
    "openai": "^4.50.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "wink-bm25-text-search": "^3.1.2"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/bun": "^1.1.0"
  }
}
